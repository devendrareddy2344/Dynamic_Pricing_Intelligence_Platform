# =============================================================================
# Dynamic Pricing Intelligence Platform — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# --- Required: Google Gemini (Vision + GenAI streaming) ---
GEMINI_API_KEY=

# Optional: override model IDs (defaults work for most regions)
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash

# --- Region & currency (single region per deployment) ---
CURRENCY=USD
CURRENCY_SYMBOL=$
REGION=us

# --- Redis (session cache, vision MD5 cache, circuit breaker state) ---
REDIS_URL=redis://redis:6379/0

# --- TimescaleDB / PostgreSQL ---
DATABASE_URL=

# --- eBay Browse API (free tier — improves eBay reliability vs HTML-only) ---
# https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# --- Scraping behaviour ---
SCRAPER_TIMEOUT_SECONDS=25
SCRAPER_MAX_RETRIES=3
MIN_SOURCES_FOR_ML=3
SCRAPER_JITTER_MIN_SEC=1.0
SCRAPER_JITTER_MAX_SEC=4.0

# --- CORS (comma-separated origins for production) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Grafana (optional defaults for docker-compose) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
